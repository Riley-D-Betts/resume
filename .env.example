# Copy to .env and fill in. docker-compose reads this file automatically;
# for a bare `node .output/server/index.mjs` deployment export them yourself.

# Password for the /ops admin console.
NUXT_ADMIN_PASSWORD=

# Secret used to sign the admin session cookie. 32+ characters required.
# Generate one:  openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# ---------------------------------------------------------------- optional

# Anonymize IPs before storing (zero the last IPv4 octet / truncate IPv6
# to its /48). Geo lookup still runs on the full IP first.
#NUXT_IP_ANONYMIZE=true

# Fraction of sessions that get rrweb replay recording, 0..1. Default 1.
#NUXT_PUBLIC_REPLAY_SAMPLE_RATE=0.5

# Use an existing GeoLite2-City.mmdb instead of auto-downloading one into
# the data dir at first boot.
#NUXT_GEOIP_MMDB_PATH=/data/geo/GeoLite2-City.mmdb

# Retention, in days. Pruning runs in the server itself — no cron needed.
#NUXT_REPLAY_RETENTION_DAYS=30
#NUXT_EVENT_RETENTION_DAYS=180
